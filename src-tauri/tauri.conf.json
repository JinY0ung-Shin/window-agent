{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Window Agent",
  "version": "0.9.4",
  "identifier": "com.gojam.tauri-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run prepare:chromium && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Window Agent",
        "width": 1400,
        "height": 800,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": [
      "../browser-sidecar/server.js",
      "../browser-sidecar/package.json",
      "../browser-sidecar/node_modules/**/*",
      "../browser-sidecar/node.exe",
      "../browser-sidecar/playwright-browsers/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English", "Korean"],
        "displayLanguageSelector": true
      }
    }
  }
}
